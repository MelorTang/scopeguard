{
  "name": "@scopeguard/desktop",
  "version": "0.4.0-preview",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-preload.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "pnpm --filter @scopeguard/server build && pnpm run build && node scripts/run-electron.mjs"
  },
  "dependencies": {
    "@scopeguard/server": "workspace:*"
  },
  "devDependencies": {
    "electron": "^42.0.1"
  }
}
